{
  "manifest_version": 3,
  "name": "Darija Side Panel Translator",
  "description": "Translate selected or typed English text into Moroccan Darija.",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "contextMenus", "storage"],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://darija-sidepanel-translator.onrender.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open Darija Translator"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
