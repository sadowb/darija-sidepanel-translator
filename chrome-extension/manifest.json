{
  "manifest_version": 3,
  "name": "Darija Side Panel Translator",
  "description": "Translate selected or typed English text into Moroccan Darija.",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "contextMenus", "storage", "activeTab"],
  "host_permissions": [
    "http://localhost:8081/*",
    "https://darija-sidepanel-translator-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "24": "icon24.png",
      "32": "icon32.png"
    },
    "default_title": "Open Darija Translator"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "options_page": "options.html",
  "key": ""
}
